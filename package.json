{
  "name": "rebel-wallet",
  "version": "1.5.0",
  "description": "Web wallet for Ravencoin",
  "private": true,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "parcel build index.html --no-source-maps",
    "watch": "parcel watch index.html",
    "start": "parcel index.html",
    "dev": "parcel index.html --https",
    "postinstall": "node generateCommitHash.js"
  },
  "keywords": [
    "Ravencoin",
    "RVN"
  ],
  "author": "Raven Rebels / Dick Henrik Larsson",
  "license": "MIT",
  "dependencies": {
    "@ravenrebels/ravencoin-history-list": "^1.2.4",
    "@ravenrebels/ravencoin-jswallet": "^0.12.4",
    "@ravenrebels/ravencoin-key": "^3.0.3",
    "@ravenrebels/ravencoin-message": "^0.7.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "crypto-js": "^4.2.0",
    "parcel": "^2.16.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-qr-reader": "^3.0.0-beta-1"
  },
  "overrides": {
    "react-qr-reader": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  },
  "devDependencies": {
    "@parcel/packager-raw-url": "^2.16.4",
    "@parcel/transformer-webmanifest": "^2.16.4",
    "assert": "^2.1.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "events": "^3.3.0",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "string_decoder": "^1.3.0",
    "vm-browserify": "^1.1.2"
  }
}
